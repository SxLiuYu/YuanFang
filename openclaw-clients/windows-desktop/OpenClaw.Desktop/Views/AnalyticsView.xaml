<UserControl x:Class="OpenClaw.Desktop.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/x2009/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <TabControl Style="{StaticResource MaterialDesignTabControl}" Margin="8">
            
            <!-- 健康评分 -->
            <TabItem Header="健康评分">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="刷新" Command="{Binding RefreshHealthCommand}"
                               Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 健康评分仪表盘 -->
                        <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="0" Margin="0,0,8,0">
                            <StackPanel Margin="32" HorizontalAlignment="Center">
                                <TextBlock Text="综合健康评分" 
                                          Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                          HorizontalAlignment="Center"/>
                                
                                <Grid Width="200" Height="200" Margin="0,32">
                                    <Ellipse Stroke="{DynamicResource MaterialDesignDivider}" 
                                            StrokeThickness="20" Width="180" Height="180"/>
                                    <Ellipse Stroke="{Binding HealthScore, Converter={StaticResource ScoreToColorConverter}}"
                                            StrokeThickness="20" Width="180" Height="180"
                                            StrokeDashArray="{Binding HealthScore}"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding HealthScore, StringFormat={}{0:F0}}"
                                                  FontSize="48" FontWeight="Bold"
                                                  Foreground="{Binding HealthScore, Converter={StaticResource ScoreToColorConverter}}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding HealthGrade}"
                                                  Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Suggestions}" Margin="0,32,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                                <TextBlock Text="💡" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 分项指标 -->
                        <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="1">
                            <StackPanel Margin="16">
                                <TextBlock Text="分项指标" 
                                          Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                          Margin="0,0,0,16"/>
                                
                                <StackPanel Margin="0,8">
                                    <TextBlock Text="心率" Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                    <ProgressBar Value="{Binding HealthComponents.HeartRate.Score}" Maximum="100"
                                                Height="8" Margin="0,4"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,8">
                                    <TextBlock Text="步数" Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                    <ProgressBar Value="{Binding HealthComponents.Steps.Score}" Maximum="100"
                                                Height="8" Margin="0,4"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,8">
                                    <TextBlock Text="睡眠" Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                    <ProgressBar Value="{Binding HealthComponents.Sleep.Score}" Maximum="100"
                                                Height="8" Margin="0,4"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,8">
                                    <TextBlock Text="血氧" Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                                    <ProgressBar Value="{Binding HealthComponents.Oxygen.Score}" Maximum="100"
                                                Height="8" Margin="0,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 消费洞察 -->
            <TabItem Header="消费洞察">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="刷新" Command="{Binding RefreshFinanceCommand}"
                               Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 收支概况 -->
                        <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="0" Margin="0,0,8,0">
                            <StackPanel Margin="16">
                                <TextBlock Text="收支概况" 
                                          Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
                                
                                <Grid Margin="0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="收入" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding FinanceInsight.TotalIncome, StringFormat=¥{0:F0}}"
                                                  Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                                  Foreground="#4CAF50" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="支出" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding FinanceInsight.TotalExpense, StringFormat=¥{0:F0}}"
                                                  Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                                  Foreground="#F44336" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Separator Margin="0,8"/>

                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="结余" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FinanceInsight.Balance, StringFormat=¥{0:F0}}"
                                              Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding FinanceInsight.Insights}" Margin="0,16,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 消费分类 -->
                        <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="1">
                            <StackPanel Margin="16">
                                <TextBlock Text="消费分类" 
                                          Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
                                
                                <ListView ItemsSource="{Binding Categories}" Margin="0,16,0,0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Category}"/>
                                                <TextBlock Grid.Column="1" 
                                                          Text="{Binding Amount, StringFormat=¥{0:F0}}"
                                                          Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 异常预警 -->
            <TabItem Header="异常预警">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="检测异常" Command="{Binding CheckAnomaliesCommand}"
                               Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding Anomalies}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MaterialDesignElevationDepth1}" Margin="4">
                                    <Grid Margin="16,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="24" VerticalAlignment="Top"/>
                                        
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="{Binding Message}"
                                                      Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                      TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Type}"
                                                      Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                      Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- 报告 -->
            <TabItem Header="报告">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="生成周报" Command="{Binding GenerateWeeklyReportCommand}"
                               Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"/>
                        <Button Content="生成月报" Command="{Binding GenerateMonthlyReportCommand}"
                               Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>

                    <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Row="1">
                        <StackPanel Margin="16">
                            <TextBlock Text="{Binding CurrentReport.Period, TargetNullValue='点击生成报告'}"
                                      Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            <TextBlock Text="{Binding CurrentReport.GeneratedAt, StringFormat=生成时间: {0}}"
                                      Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                      Foreground="{DynamicResource MaterialDesignBodyLight}"
                                      Margin="0,4,0,16"/>
                            
                            <TextBlock Text="报告内容将在此显示..."
                                      Style="{StaticResource MaterialDesignBody1TextBlock}"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <ProgressBar IsIndeterminate="{Binding IsLoading}"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalAlignment="Top" Height="4"/>
    </Grid>
</UserControl>