<UserControl x:Class="OpenClaw.Desktop.Views.FamilyGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/x2009/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：群组列表 -->
        <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="0" Margin="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <TextBlock Grid.Row="0" Text="我的家庭" 
                          Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                          Margin="16"/>

                <!-- 创建/加入群组 -->
                <StackPanel Grid.Row="1" Margin="16,0,16,16">
                    <TextBox ToolTip="群组名称"
                            Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Margin="0,0,0,8"/>
                    <Button Content="创建群组"
                           Command="{Binding CreateGroupCommand}"
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           HorizontalAlignment="Stretch"/>

                    <TextBox ToolTip="邀请码"
                            Text="{Binding InviteCode, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Margin="0,16,0,8"/>
                    <Button Content="加入群组"
                           Command="{Binding JoinGroupCommand}"
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- 群组列表 -->
                <ListView Grid.Row="2" ItemsSource="{Binding MyGroups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Margin="0,8">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Margin="8,4">
                                <Grid Margin="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="👥" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Name}" 
                                                  Style="{StaticResource MaterialDesignSubtitle2TextBlock}"/>
                                        <TextBlock Text="{Binding MyRole}"
                                                  Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                  Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- 右侧：群组详情 -->
        <Grid Grid.Column="1" Margin="8,8,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 群组信息 -->
            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Row="0" Margin="0,0,0,8">
                <StackPanel Margin="16" Orientation="Horizontal">
                    <TextBlock Text="👥" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedGroup.Name}" 
                                  Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        <TextBlock Text="{Binding SelectedGroup.InviteCode, StringFormat='邀请码: {0}'}"
                                  Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                  Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 标签页 -->
            <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignTabControl}">
                <!-- 成员列表 -->
                <TabItem Header="成员">
                    <Grid>
                        <ListView ItemsSource="{Binding Members}" Margin="8">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Width="40" Height="40"
                                               CornerRadius="20" Background="{DynamicResource PrimaryHueMidBrush}">
                                            <TextBlock Text="{Binding Name[0]}" 
                                                      Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      FontWeight="Bold"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                      Style="{StaticResource MaterialDesignSubtitle2TextBlock}"/>
                                            <TextBlock Text="{Binding Role}"
                                                      Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                      Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2" Content="移除"
                                               Style="{StaticResource MaterialDesignFlatButton}"
                                               Visibility="{Binding Role, Converter={StaticResource RoleToVisibilityConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- 共享日程 -->
                <TabItem Header="日程">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Content="新建日程"
                               Command="{Binding CreateScheduleCommand}"
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               HorizontalAlignment="Right" Margin="16"/>

                        <ListView Grid.Row="1" ItemsSource="{Binding Schedules}" Margin="8">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MaterialDesignElevationDepth1}" Margin="4">
                                        <Grid Margin="12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="📅" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Title}"
                                                          Style="{StaticResource MaterialDesignSubtitle2TextBlock}"/>
                                                <TextBlock Text="{Binding StartTime, StringFormat='{}{0:MM月dd日 HH:mm}'}"
                                                          Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                          Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- 位置共享 -->
                <TabItem Header="位置">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Content="分享我的位置"
                               Command="{Binding ShareLocationCommand}"
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               HorizontalAlignment="Right" Margin="16"/>

                        <ListView Grid.Row="1" ItemsSource="{Binding MemberLocations}" Margin="8">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MaterialDesignElevationDepth1}" Margin="4">
                                        <Grid Margin="12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="📍" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                          Style="{StaticResource MaterialDesignSubtitle2TextBlock}"/>
                                                <TextBlock Text="{Binding Address}"
                                                          Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                          Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                          TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- 加载指示器 -->
        <ProgressBar Grid.Column="0" Grid.ColumnSpan="2"
                    IsIndeterminate="{Binding IsLoading}"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalAlignment="Top" Height="4"/>
    </Grid>
</UserControl>