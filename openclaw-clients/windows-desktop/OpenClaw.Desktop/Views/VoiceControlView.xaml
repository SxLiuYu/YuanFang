<UserControl x:Class="OpenClaw.Desktop.Views.VoiceControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/x2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Row="0" Margin="16" Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎤" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="语音控制中心" Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 语音交互区域 -->
        <Grid Grid.Row="1" Margin="16,0,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 声波可视化区域 -->
            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Row="0" VerticalAlignment="Center" Margin="32">
                <Grid Margin="32">
                    <lvc:CartesianChart Series="{Binding WaveSeries}" 
                                       Height="200"
                                       Background="Transparent"/>
                    
                    <!-- 麦克风图标 -->
                    <Viewbox Width="80" Height="80">
                        <TextBlock Text="🎤" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- 控制按钮 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16">
                <Button Command="{Binding ToggleListeningCommand}"
                       Style="{StaticResource MaterialDesignFloatingActionButton}"
                       Width="80" Height="80"
                       
                       Background="{DynamicResource PrimaryHueMidBrush}">
                    <TextBlock Text="🎤" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                
                <Button Command="{Binding ClearCommand}"
                       Style="{StaticResource MaterialDesignFloatingActionButton}"
                       Width="56" Height="56"
                       Margin="16,0,0,0"
                       
                       Background="{DynamicResource SecondaryHueMidBrush}">
                    <TextBlock Text="✖️" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                </Button>
            </StackPanel>

            <!-- 识别文本显示 -->
            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Row="2" Margin="16,8">
                <StackPanel Margin="16">
                    <TextBlock Text="识别结果:" Style="{StaticResource MaterialDesignBody2TextBlock}"
                              Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding RecognizedText}" 
                              Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                              TextWrapping="Wrap" Margin="0,8,0,0"/>
                    
                    <TextBlock Text="系统回复:" Style="{StaticResource MaterialDesignBody2TextBlock}"
                              Foreground="{DynamicResource MaterialDesignBodyLight}"
                              Margin="0,16,0,0"/>
                    <TextBlock Text="{Binding ResponseMessage}"
                              Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                              TextWrapping="Wrap" Margin="0,8,0,0"
                              Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 分隔线 -->
        <Separator Grid.Row="2" Margin="16,8"/>

        <!-- 智能建议区域 -->
        <Grid Grid.Row="3" Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="智能建议" 
                      Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                      Margin="0,0,0,8"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Suggestions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Width="200" Height="120" Margin="8"
                                               >
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="{Binding Title}"
                                              Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                              Margin="12,8,12,0"/>
                                    
                                    <TextBlock Grid.Row="1" Text="{Binding Description}"
                                              Style="{StaticResource MaterialDesignBody2TextBlock}"
                                              TextWrapping="Wrap" Margin="12,4,12,0"
                                              Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    
                                    <Button Grid.Row="2" Content="执行"
                                           Command="{Binding DataContext.ExecuteSuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding}"
                                           Style="{StaticResource MaterialDesignFlatButton}"
                                           HorizontalAlignment="Right" Margin="8"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- 加载指示器 -->
        <ProgressBar Grid.Row="0" Grid.RowSpan="4"
                    IsIndeterminate="{Binding IsProcessing}"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalAlignment="Top" Height="4"/>
    </Grid>
</UserControl>