<UserControl x:Class="OpenClaw.Desktop.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Command="{Binding RefreshCommand}" Style="{DynamicResource MaterialDesignFlatButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding AddIncomeCommand}" Style="{DynamicResource MaterialDesignRaisedButton}"
                    Background="Green">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="➕" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Income"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding AddExpenseCommand}" Style="{DynamicResource MaterialDesignRaisedButton}"
                    Background="Red" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="➖" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Expense"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Padding="16" Margin="0,0,8,0" Background="#E8F5E9">
                <StackPanel>
                    <TextBlock Text="Total Income" Style="{DynamicResource MaterialDesignCaptionTextBlock}"/>
                    <TextBlock Text="{Binding Summary.TotalIncome, StringFormat=¥{0:N2}}" 
                              FontSize="24" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Padding="16" Margin="8,0,8,0" Background="#FFEBEE">
                <StackPanel>
                    <TextBlock Text="Total Expense" Style="{DynamicResource MaterialDesignCaptionTextBlock}"/>
                    <TextBlock Text="{Binding Summary.TotalExpense, StringFormat=¥{0:N2}}" 
                              FontSize="24" FontWeight="Bold" Foreground="Red"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Padding="16" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Balance" Style="{DynamicResource MaterialDesignCaptionTextBlock}"/>
                    <TextBlock Text="{Binding Summary.Balance, StringFormat=¥{0:N2}}" 
                              FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="0" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Income vs Expense" FontSize="18" Margin="16"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding IncomeExpenseSeries}"
                                       Background="Transparent"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Expense Categories" FontSize="18" Margin="16"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding ExpenseSeries}"
                                 Background="Transparent"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>