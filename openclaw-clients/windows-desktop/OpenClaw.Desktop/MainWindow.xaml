<Window x:Class="OpenClaw.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="OpenClaw Desktop" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🐾" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="OpenClaw" FontSize="22" VerticalAlignment="Center" FontWeight="Medium"/>
                </StackPanel>
                <TextBlock Text="{Binding CurrentViewTitle}" FontSize="18" 
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button ToolTip="Settings" Command="{Binding NavigateToSettingsCommand}"
                            Style="{DynamicResource MaterialDesignFlatButton}">
                        <TextBlock Text="⚙️" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </Button>
                    <Button ToolTip="Minimize to Tray" Command="{Binding MinimizeToTrayCommand}"
                            Style="{DynamicResource MaterialDesignFlatButton}">
                        <TextBlock Text="➖" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource MaterialDesignElevationDepth1}" Grid.Column="0" Margin="8">
                <ListBox ItemsSource="{Binding MenuItems}" 
                        SelectedItem="{Binding SelectedMenuItem}"
                        Margin="0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,4">
                                <TextBlock Text="●" FontSize="16" Margin="0,0,12,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="{Binding Title}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Frame Grid.Column="1" NavigationUIVisibility="Hidden" 
                   Content="{Binding CurrentView}"/>
        </Grid>

        <materialDesign:Snackbar Grid.Row="1" Grid.ColumnSpan="2"
                                 VerticalAlignment="Bottom"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,16"/>
    </Grid>
</Window>
