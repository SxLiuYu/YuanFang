<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 搜索区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/edt_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="搜索菜谱"/>

        <Button
            android:id="@+id/btn_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="搜索"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btn_voice_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="语音"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 菜谱列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_recipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"/>

    <!-- 当前步骤 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="当前步骤"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/txt_current_step"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请选择菜谱开始制作"
        android:textSize="14sp"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="12dp"/>

    <!-- 步骤控制 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_prev_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="上一步"/>

        <Button
            android:id="@+id/btn_repeat_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重复"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_next_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="下一步"/>
    </LinearLayout>

    <!-- 计时器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/txt_timer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <Button
            android:id="@+id/btn_start_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="计时"/>

        <Button
            android:id="@+id/btn_stop_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 添加到购物清单 -->
    <Button
        android:id="@+id/btn_add_to_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="添加食材到购物清单"/>

</LinearLayout>