<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 智能家居"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"/>

        <!-- 场景快捷按钮 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_home_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 回家"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_away_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚪 离家"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_sleep_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😴 睡眠"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_work_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💼 工作"
                    android:layout_marginEnd="8dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- 房间选择 -->
        <Spinner
            android:id="@+id/spinner_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/btn_dropdown"
            android:padding="12dp"/>

        <!-- 设备列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_devices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- 能耗统计 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ 能耗统计"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txt_energy_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日总耗电：0 kWh"
            android:textSize="14sp"
            android:textColor="#666666"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- 添加设备按钮 -->
        <Button
            android:id="@+id/btn_add_device"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ 添加设备"
            android:backgroundTint="#4CAF50"/>

    </LinearLayout>
</ScrollView>
