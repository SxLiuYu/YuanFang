<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- 标题栏 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OpenClaw AI"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- 对话历史 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollConversation"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:overScrollMode="always">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvConversation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 你好！我是你的家庭助手。\n\n直接告诉我你需要什么，我会尽力帮你！\n\n💡 我可以：\n• 聊天解闷\n• 查询天气、资讯\n• 设置提醒\n• 控制智能家居\n• 解答问题\n\n试试说：今天天气怎么样？"
                android:textSize="16sp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 输入区 - 简约圆角设计 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@color/bg_card"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="告诉我你需要什么..."
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:background="@null"
            android:inputType="textMultiLine"
            android:imeOptions="actionSend"
            android:maxLines="4"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="发送"
            android:textColor="@color/white"
            android:background="@drawable/bg_send_button"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
