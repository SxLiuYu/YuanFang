# ====== AI 模型 API ======
FINNA_API_KEY=
FINNA_API_BASE=https://www.finna.com.cn/v1
DEEPSEEK_MODEL=Pro/deepseek-ai/DeepSeek-V3.1-Terminus
KIMI_API_KEY=
GLM_API_KEY=
QWEN_VL_API_KEY=
COSYVOICE_API_KEY=

# ====== Ollama 本地模型（M12: 可选） ======
# 安装: https://ollama.ai  →  ollama pull qwen2.5:14b
OLLAMA_BASE=http://localhost:11434
# DEFAULT_MODEL=qwen2.5:14b  # 取消注释以使用本地模型替代云端

# ====== Embedding 模型 ======
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# ====== Telegram Bot（M12: 可选） ======
# 创建: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false
# 白名单: 逗号分隔的 Telegram User ID（留空则允许所有用户）
TELEGRAM_ALLOWED_USERS=

# ====== MQTT 设备（M12: 可选） ======
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# 设备配置文件路径
MQTT_DEVICES_CONFIG=

# ====== SwitchBot（M12: 可选） ======
# 获取: https://developer.switch-bot.com/
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=

# ====== Frigate 摄像头（M12: 可选） ======
# Docker: docker run -d --name frigate -p 5000:5000 ghcr.io/blakeblackshear/frigate:stable
FRIGATE_URL=http://localhost:5000

# ====== 服务端口 ======
PORT=8000

# ====== 在家检测 ======
HOME_WIFI=YourHomeWiFiSSID

# ====== Home Assistant（可选） ======
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# ====== 唤醒词引擎（可选，需 Porcupine） ======
# 获取: https://console.picovoice.ai/ 免费注册
PORCUPINE_ACCESS_KEY=
# 自定义唤醒词 .ppn 文件路径（在 Picovoice Console 创建"元芳"后下载）
WAKE_WORD_PPN=
# 中文语言模型 .pv 文件（从 Porcupine GitHub 下载）
# https://github.com/Picovoice/porcupine/tree/master/lib/common
PORCUPINE_MODEL=
# 唤醒灵敏度 0.0~1.0（越高越灵敏，误触越多）
WAKE_WORD_SENSITIVITY=0.5
# 无自定义词时的备选内置词
FALLBACK_KEYWORD=porcupine
# 唤醒后录音时长（秒）
RECORD_SECONDS=5

# ====== Termux 节点（可选，传感器客户端默认值） ======
TERMUX_API=http://192.168.1.10:8080
TERMUX_NODE_ID=termux_sensor_01

# ====== KAIROS 守护进程 ======
KAIROS_ENABLED=true
# tick 间隔（秒）
KAIROS_TICK_INTERVAL=60
# 梦境触发：对话次数阈值
DREAM_CHAT_THRESHOLD=15
# 梦境冷却（分钟）
DREAM_COOLDOWN_MINUTES=30

# ====== 安全配置 ======
API_AUTH_TOKEN=
# CORS 允许的来源（逗号分隔，* 表示全部）
CORS_ORIGINS=*
# 速率限制：每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60
